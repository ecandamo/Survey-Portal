generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Token {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  usedAt    DateTime?
  response  Response?
}

model Response {
  id                 String   @id @default(cuid())
  tokenId            String   @unique
  token              Token    @relation(fields: [tokenId], references: [id])
  role               String
  overallValue       Int
  pipelineValue      Int
  huddleValue        Int
  timeInvestment     String
  pipelineChanges    String[]
  pipelineOther      String?
  huddleChanges      String[]
  huddleOther        String?
  meetingTiming      String
  improveOneThing    String?
  anythingElse       String?
  createdAt          DateTime @default(now())
}
